target/
dist/
.DS_Store

# SpecSlice local runtime state.
.specslice/graph.db
.specslice/export/
.specslice/stats.jsonl

# Rust/editor local files.
*.swp

# 对标基准：CodeGraph 等第三方仓的 vendored 源码副本，仅作本地对标用，
# 不纳入本仓库历史（体积大、属第三方代码）。
docs/sourcecode/

# Dart sidecar local build artefacts (we commit pubspec.yaml but not the
# resolved pubspec.lock or the on-disk pub cache).
tool/specslice_dart_analyzer/.dart_tool/
tool/specslice_dart_analyzer/build/
tool/specslice_dart_analyzer/pubspec.lock

# P20 multi-language fixtures — we ship the source trees but never the
# resolved tooling outputs. `target/` is already gitignored at the
# repo root for the Rust workspace; these patterns explicitly catch
# the JVM / Node tooling outputs that would otherwise leak in if an
# operator runs `mvn`, `npm install`, or `tsc` against the fixtures.
tests/fixtures/java_hello/target/
tests/fixtures/typescript_hello/node_modules/
tests/fixtures/typescript_hello/dist/
tests/fixtures/typescript_hello/.turbo/
**/*.class

# v0.2.0 收口扫描 — 把外部仓的源码 rsync 到本地 scratch 树跑扫描，
# 这样目标仓库本身保持完全无副作用（连 .specslice/graph.db 都不会落到
# 用户的代码库里）。scratch 副本和导出的图 HTML 不纳入版本控制；
# 只把摘要 Markdown 报告 (reports/release/*.md) 入库作为发版证据。
release-scans/_scratch/
release-scans/*.log
# Release report 体积大小不一：vub 单仓 graph.json 25MB，pixcraft-app 7MB。
# 不把这些 JSON 入库；摘要数据由 reports/release/<name>/report.md 和
# reports/release/README.md 引用。需要二次分析时本地复跑 release_scan.sh
# 重新生成。
reports/release/**/graph-*.json
reports/release/**/dead-code-*.json
reports/release/**/graph.html
reports/release/**/*.db
reports/release/**/.specslice/
# Raw `specslice <cmd>` stdout per fixture is regenerated by
# `bash scripts/release_scan.sh`; the polished evidence lives in
# `reports/release/<name>/report.md`, so we keep only the markdown
# and gitignore the .txt to keep `git log -p` reviewable.
reports/release/**/*.txt
reports/release-v0.3.0a/**/*.json
